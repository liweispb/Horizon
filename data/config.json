{
  "version": "1.0",
  "ai": {
    "provider": "minimax",
    "model": "MiniMax-M2.7",
    "base_url": "https://api.minimaxi.com/v1",
    "api_key_env": "MINIMAX_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh",
      "en"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 150
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": true,
        "category": "linux-kernel"
      },
      {
        "name": "TechCrunch",
        "url": "https://techcrunch.com/feed/",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "The Verge",
        "url": "https://www.theverge.com/rss/index.xml",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "Ars Technica",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "VentureBeat AI",
        "url": "https://venturebeat.com/category/ai/feed/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "MIT Tech Review",
        "url": "https://www.technologyreview.com/feed/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Hacker News Frontpage",
        "url": "https://hnrss.org/frontpage",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "GitHub Blog",
        "url": "https://github.blog/feed/",
        "enabled": true,
        "category": "dev"
      },
      {
        "name": "DEV Community",
        "url": "https://dev.to/feed/",
        "enabled": true,
        "category": "dev"
      },
      {
        "name": "InfoQ",
        "url": "https://feed.infoq.com/",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "Slashdot",
        "url": "https://rss.slashdot.org/Slashdot/slashdotMain",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "AI News ( import AI )",
        "url": "https://www.artificialintelligence-news.com/feed/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "DeepMind Blog",
        "url": "https://deepmind.google/blog/rss.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Anthropic Blog",
        "url": "https://www.anthropic.com/blog/rss.xml",
        "enabled": true,
        "category": "ai"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
